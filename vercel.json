{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/pdfs/(.*)",
      "headers": [
        { "key": "Content-Disposition", "value": "inline" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
